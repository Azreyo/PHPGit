{
  "name": "azreyo/phpgit",
  "description": "PHPGit is a web-based Git repository hosting platform built with clean PHP.",
  "license": "MIT",
  "type": "project",
    "require": {
        "php": "^8.4",
        "vlucas/phpdotenv": "^5.6",
      "ext-pdo": "*",
      "ext-curl": "*",
      "ext-mbstring": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3",
    "phpstan/phpstan": "^2.1",
    "vimeo/psalm": "^6.16",
    "jetbrains/phpstorm-stubs": "^2025.3",
    "fakerphp/faker": "^1.24"
  }
}
