# APP STATE
# if set to prod == production -> no dev bar available displayed as plain site
# else set to dev == developement -> dev bar at bottom of site will be generated displaying usefull stuff
APP_ENV=dev

# DB config
DB_HOST=127.0.0.1
DB_NAME=db
DB_USER=user
DB_PASS=pass

# Filesystem path where bare git repositories are stored (data/{username}/{repo_name})
# Defaults to <project_root>/data if not set
DATA_ROOT=/var/www/phpgit/data
