# APP STATE
# if set to prod == production -> no dev bar available displayed as plain site
# else set to dev == developement -> dev bar at bottom of site will be generated displaying usefull stuff
APP_ENV=dev

# DB config
DB_HOST=127.0.0.1
DB_NAME=db
DB_USER=user
DB_PASS=pass

# Filesystem path where bare git repositories are stored (data/{username}/{repo_name})
# Defaults to <project_root>/data if not set
DATA_ROOT=/var/www/phpgit/data

# Git server – SSH settings
# System user that owns the SSH git shell (used in authorized_keys and clone URL hints)
GIT_SYSTEM_USER=git
# Absolute path to the git system user's authorized_keys file
AUTHORIZED_KEYS_PATH=/home/git/.ssh/authorized_keys
# Absolute path to the SSH shell wrapper script
GIT_SHELL_WRAPPER=/var/www/phpgit/bin/git-shell-wrapper.php
# Hostname shown in SSH clone URLs (defaults to HTTP_HOST if unset)
SSH_HOST=phpgit.local

