Options -Indexes
DirectoryIndex index.php
<FilesMatch "(^\.env(\..*)?$|config\.php|composer\.(json|lock)$)">
    Require all denied
</FilesMatch>

<FilesMatch "\.(?:env|ini|log|sql|bak|dist|md)$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Pass HTTP Authorization header to PHP (needed for git HTTP auth)
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteRule ^(assets/(?:(?:css|js)/[^/]+|img/[^/]+))\.[a-f0-9]{8}\.(css|js|png|jpg|jpeg|gif|svg|webp|ico)$ /$1.$2 [L]

    # Block rarely used HTTP methods to reduce attack surface.
    RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK)$ [NC]
    RewriteRule ^ - [F,L]

    RewriteRule ^(?:vendor|log|certs)(?:/|$) - [F,L,NC]

    # Git HTTP Smart Protocol: {user}/{repo}.git/...  →  git.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^([a-zA-Z0-9][a-zA-Z0-9_-]{0,49})/([a-zA-Z0-9][a-zA-Z0-9._-]{0,98})\.git(/.*)?$ git.php?_git_user=$1&_git_repo=$2&_git_path=$3 [L,QSA]

    # Pretty repo URLs: username/repo_name -> repo_view page
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([a-zA-Z0-9][a-zA-Z0-9_-]{0,49})/([a-zA-Z0-9][a-zA-Z0-9._-]{0,98})/?$ index.php?page=repo_view&slug=$1/$2 [L,QSA]

    # Pretty profile URLs: username -> profile_view page
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php !-f
    RewriteCond %{REQUEST_URI} !^/(?:api|assets|includes|pages|vendor|log|certs)(?:/|$) [NC]
    RewriteCond %{REQUEST_URI} !^/(?:index\.php|git\.php)$ [NC]
    RewriteCond %{REQUEST_URI} !^/(?:home|about|contact|explore|login|register|logout|terms|settings|repos|new_repo|dashboard|phpinfo|404|403|414)$ [NC]
    RewriteRule ^([a-zA-Z0-9][a-zA-Z0-9_-]{0,49})/?$ index.php?page=profile_view&user=$1 [L,QSA]

    # Allow extensionless
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+)$ $1.php [L,QSA]

    RewriteRule ^(includes|pages)(/|$) - [F,L]
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"

    <FilesMatch "\.(?:css|js|png|jpg|jpeg|gif|svg|webp|ico|woff2?|ttf)$">
        Header set Cache-Control "public, max-age=604800, immutable"
    </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType text/javascript "access plus 7 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/x-icon "access plus 30 days"
    ExpiresByType font/ttf "access plus 30 days"
    ExpiresByType font/woff "access plus 30 days"
    ExpiresByType font/woff2 "access plus 30 days"
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

#php_value opcache.enable 1

<IfModule mod_proxy.c>
    <IfModule mod_proxy_fcgi.c>
        <FilesMatch \.php$>
            <If "%{ENV:PHP_FPM_SOCKET} != ''">
                SetHandler "proxy:unix:%{ENV:PHP_FPM_SOCKET}|fcgi://localhost/"
            </If>
            <Else>
                SetHandler "proxy:unix:/run/php/php8.4-fpm.sock|fcgi://localhost/"
            </Else>
        </FilesMatch>
    </IfModule>
</IfModule>

ErrorDocument 404 /index.php?page=404
ErrorDocument 403 /index.php?page=403
ErrorDocument 414 /index.php?page=414